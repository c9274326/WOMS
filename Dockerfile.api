FROM golang:1.22-alpine AS build
WORKDIR /src
COPY go.mod ./
COPY cmd ./cmd
COPY internal ./internal
RUN go test ./...
RUN CGO_ENABLED=0 GOOS=linux go build -o /out/woms-api ./cmd/api

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=build /out/woms-api /woms-api
EXPOSE 8080
ENTRYPOINT ["/woms-api"]
