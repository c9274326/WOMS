APP_ENV=local
HTTP_ADDR=:8080
JWT_SECRET=change-me-in-production
API_STORE=postgres
DEMO_SEED_DATA=true
DATABASE_URL=postgres://woms:woms@postgres:5432/woms?sslmode=disable
REDIS_ADDR=redis:6379
KAFKA_BROKERS=kafka:9092
KAFKA_SCHEDULE_TOPIC=woms.schedule.jobs
KAFKA_PUBLISH_ENABLED=true
WORKER_MIN_JOB_DURATION_MS=500
WORKER_MAX_RETRIES=3
DOCKERHUB_NAMESPACE=your-dockerhub-namespace
WOMS_IMAGE_TAG=latest
